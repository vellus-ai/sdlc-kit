{
  "name": "sdlc-kit",
  "version": "0.1.0",
  "description": "Spec-Driven Development vault for Claude Code projects — 20 skills, SDD/DDD, dashboard, git worktrees",
  "author": {
    "name": "Vellus AI",
    "email": "contato@vellus.tech",
    "url": "https://github.com/vellus-ai"
  },
  "homepage": "https://github.com/vellus-ai/sdlc-kit",
  "repository": "https://github.com/vellus-ai/sdlc-kit",
  "license": "MIT",
  "keywords": [
    "sdd",
    "spec-driven-development",
    "ddd",
    "vault",
    "obsidian",
    "adr",
    "kanban",
    "worktree",
    "c4-diagrams",
    "productivity"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/post-vault-write.py\""
          }
        ]
      }
    ]
  }
}
